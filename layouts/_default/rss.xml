{{/* Default RSS feed. Page selection differs per section;
     the channel structure lives in partials/rss-feed.html. */}}
{{- $pages := slice -}}
{{- if .IsHome -}}
  {{- $pages = where .Site.RegularPages.ByLastmod.Reverse ".Params.unlisted" "ne" true -}}
{{- else -}}
  {{- $pages = where .Pages.ByLastmod.Reverse ".Params.unlisted" "ne" true -}}
{{- end -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = $pages | first $limit -}}
{{- end -}}
{{- partial "rss-feed.html" (dict "context" . "pages" $pages) -}}

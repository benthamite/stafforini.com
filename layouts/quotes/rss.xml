{{/* Quotes RSS feed — diary quotes only. Page selection differs
     from _default/rss.xml; channel structure lives in partials/rss-feed.html. */}}
{{- $pages := where .Pages ".Params.diary" true -}}
{{- $pages = $pages.ByDate.Reverse -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = $pages | first $limit -}}
{{- end -}}
{{- partial "rss-feed.html" (dict "context" . "pages" $pages) -}}

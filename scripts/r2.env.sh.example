#!/usr/bin/env bash
# Copy this file to scripts/r2.env.sh (gitignored) and either fill in the
# values directly or use 1Password op:// references + `op run`.
#
# Direct-values approach:
#   export R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
#   export R2_BUCKET="stafforini-pdfs"
#   export AWS_ACCESS_KEY_ID="<R2 API token access key>"
#   export AWS_SECRET_ACCESS_KEY="<R2 API token secret>"
#
# 1Password approach (preferred -- secrets stay in the vault):
#   export R2_ENDPOINT="op://Private/stafforini-r2/endpoint"
#   export R2_BUCKET="op://Private/stafforini-r2/bucket"
#   export AWS_ACCESS_KEY_ID="op://Private/stafforini-r2/access-key"
#   export AWS_SECRET_ACCESS_KEY="op://Private/stafforini-r2/secret-key"
#
# Then invoke with:
#   op run --env-file=scripts/r2.env.sh -- bash scripts/upload-pdfs.sh
